---
import Base from '../layouts/Base.astro';

const piliers = [
  {
    icon: 'fa-brain',
    tone: 'orange',
    title: 'Diagnostic Lucide',
    text: 'Six axes, trente questions, vingt minutes. Une photographie honnête de votre maturité digitale, sans jargon ni complaisance.',
  },
  {
    icon: 'fa-chart-line',
    tone: 'navy',
    title: 'Plan Orienté ROI',
    text: 'Des recommandations priorisées par impact et faisabilité, traduites en quick wins activables sur 30 à 90 jours.',
  },
  {
    icon: 'fa-cogs',
    tone: 'orange',
    title: 'Exécution par l’IA',
    text: 'Automatisation des processus, data exploitable, outils connectés : nous transformons le diagnostic en résultats mesurables.',
  },
];
---

<Base>
  <!-- HERO -->
  <section class="section hero">
    <div class="container hero__inner">
      <p class="hero__eyebrow">SYMBOTIS · TRANSFORMATION DIGITALE PAR L’IA</p>
      <h1 class="hero__title">Mesurez Votre Maturité Digitale en 20 Minutes</h1>
      <p class="hero__lead">
        Symbotis accompagne les dirigeants qui veulent passer du digital subi au
        digital piloté. Commencez par un diagnostic clair&nbsp;: vous saurez où vous
        en êtes, et surtout par où commencer.
      </p>
      <div class="hero__actions">
        <a class="btn-cta" href="/diagnostic-maturite-digitale">
          💡 Lancer Le Diagnostic
        </a>
        <span class="hero__promise">
          <i class="fa-solid fa-circle-check" aria-hidden="true"></i> ROI garanti 30–90 jours
        </span>
      </div>
    </div>
  </section>

  <!-- PILIERS -->
  <section class="section section--wash">
    <div class="container">
      <h2 class="section__title">Notre Approche</h2>
      <p class="section__sub">
        Trois temps pour transformer une intuition en feuille de route actionnable.
      </p>
      <div class="piliers">
        {
          piliers.map((p) => (
            <article class="card pilier">
              <div class:list={['pilier__icon', `pilier__icon--${p.tone}`]}>
                <i class:list={['fa-solid', p.icon]} aria-hidden="true" />
              </div>
              <h3 class="pilier__title">{p.title}</h3>
              <p class="pilier__text">{p.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section cta-band">
    <div class="container cta-band__inner">
      <h2 class="cta-band__title">Prêt à Y Voir Clair&nbsp;?</h2>
      <p class="cta-band__text">
        Le diagnostic est gratuit, immédiat et sans inscription. Vos réponses
        restent sur votre navigateur.
      </p>
      <a class="btn-cta" href="/diagnostic-maturite-digitale">
        💡 Démarrer Mon Diagnostic
      </a>
      <p class="cta-band__quote">
        «&nbsp;On ne transforme bien que ce que l’on a d’abord regardé en face.&nbsp;»
      </p>
    </div>
  </section>

  <style>
    /* HERO */
    .hero__inner {
      max-width: 820px;
    }
    .hero__eyebrow {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      color: var(--brand-navy);
      margin: 0 0 1rem;
    }
    .hero__title {
      font-size: clamp(2.1rem, 5vw, 3.2rem);
      font-weight: 800;
      color: var(--brand-orange);
      margin: 0 0 1.1rem;
    }
    .hero__lead {
      font-size: 1.18rem;
      color: var(--slate-600);
      margin: 0 0 2rem;
      max-width: 64ch;
    }
    .hero__actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1.25rem;
    }
    .hero__promise {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-weight: 600;
      color: var(--brand-navy);
    }
    .hero__promise i {
      color: var(--brand-success);
    }

    /* Titres de section */
    .section__title {
      font-size: clamp(1.7rem, 3.5vw, 2.3rem);
      color: var(--slate-800);
      text-align: center;
      margin: 0 0 0.6rem;
    }
    .section__sub {
      text-align: center;
      color: var(--slate-500);
      max-width: 56ch;
      margin: 0 auto 3rem;
    }

    /* PILIERS */
    .piliers {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.75rem;
    }
    .pilier {
      text-align: left;
    }
    .pilier__icon {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1.1rem;
    }
    .pilier__icon--orange {
      background: rgba(243, 148, 72, 0.14);
      color: var(--brand-orange-cta);
    }
    .pilier__icon--navy {
      background: rgba(31, 42, 99, 0.1);
      color: var(--brand-navy);
    }
    .pilier__title {
      font-size: 1.2rem;
      color: var(--slate-800);
      margin: 0 0 0.5rem;
    }
    .pilier__text {
      color: var(--slate-600);
      margin: 0;
    }

    /* CTA FINAL */
    .cta-band__inner {
      text-align: center;
      max-width: 640px;
    }
    .cta-band__title {
      font-size: clamp(1.7rem, 3.5vw, 2.3rem);
      color: var(--slate-800);
      margin: 0 0 0.8rem;
    }
    .cta-band__text {
      color: var(--slate-600);
      margin: 0 0 2rem;
    }
    .cta-band__quote {
      margin: 2.5rem 0 0;
      font-style: italic;
      color: var(--slate-500);
    }
  </style>
</Base>
